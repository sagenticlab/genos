{
  "compilerOptions": {
  "module": "NodeNext",
  "moduleResolution": "NodeNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node"]
  }
}